{
  "name": "@freehour/supabase-langchain",
  "private": false,
  "displayName": "Supabase-Langchain",
  "description": "Integration package for using LangChain with Supabase",
  "version": "1.3.2",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freehour/supabase-langchain.git"
  },
  "scripts": {
    "lint": "eslint ./lib --ext ts",
    "build": "bun run lint && tsc && vite build",
    "postinstall": "bun ./scripts/copy-supabase-assets.js"
  },
  "files": [
    "dist",
    "supabase/migrations/0001_supabase_langchain.sql",
    "supabase/schemas/supabase-langchain",
    "scripts/copy-supabase-assets.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "dependencies": {
    "@freehour/mime": "^1.1.14",
    "@langchain/classic": "^1.0.34",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.48",
    "@langchain/textsplitters": "^1.0.1",
    "langchain": "^1.4.2",
    "officeparser": "^6.1.1",
    "pdf-parse": "^2.4.5",
    "srt-parser-2": "^1.2.3"
  },
  "peerDependencies": {
    "@freehour/supabase-core": "^2.5.2",
    "@supabase/supabase-js": "^2.106.2"
  },
  "overrides": {
    "@browserbasehq/stagehand": "3.2.1"
  },
  "devDependencies": {
    "@freehour/supabase-core": "^2.5.2",
    "@freehour/eslint-rules": "^1.0.19",
    "@supabase/supabase-js": "^2.106.2",
    "ajv": "^8.20.0",
    "bun-types": "^1.3.14",
    "eslint": "9.39.4",
    "supabase": "^2.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1"
  },
  "trustedDependencies": [
    "@freehour/supabase-core",
    "supabase",
    "tesseract.js",
    "tree-sitter",
    "unrs-resolver"
  ]
}